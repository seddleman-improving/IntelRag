# =============================================================================
# Consulting Intelligence Platform — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python — UV virtual environments (both root BMad env and backend app env)
# -----------------------------------------------------------------------------
.venv/
*.pyc
*.pyo
__pycache__/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Backend — secrets and generated data
# -----------------------------------------------------------------------------
backend/.env
backend/chroma_db/

# -----------------------------------------------------------------------------
# Frontend — Node
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/

# -----------------------------------------------------------------------------
# OS metadata
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# IDE — JetBrains
# -----------------------------------------------------------------------------
.idea/

# -----------------------------------------------------------------------------
# IDE — VS Code (commit settings.json for shared workspace config, exclude rest)
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.tmp
*.swp
.env
